{
  "name": "bunbook",
  "displayName": "BunBook",
  "description": "Run TypeScript as a native VS Code notebook with Plotly support",
  "version": "0.0.12",
  "publisher": "DavidBuezas",
  "license": "MIT",
  "repository": "https://github.com/dbuezas/bunbook",
  "keywords": [
    "typescript",
    "notebook",
    "jupyter",
    "bun",
    "plotly",
    "interactive",
    "notebookKernelJupyterNotebook"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Notebooks"
  ],
  "activationEvents": [
    "onNotebook:jupyter-notebook"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "notebooks": [
      {
        "type": "bunbook",
        "displayName": "BunBook — TypeScript (Bun), outputs not saved",
        "priority": "default",
        "selector": [
          {
            "filenamePattern": "*.no-output.ipynb"
          },
          {
            "filenamePattern": "*.bunbook"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "bunbook.restartKernel",
        "title": "Restart Kernel",
        "shortTitle": "Restart",
        "icon": "$(debug-restart)"
      },
      {
        "command": "bunbook.enableSaveOutputs",
        "title": "BunBook: Outputs NOT saved to file (click to enable)",
        "shortTitle": "Save Outputs Off",
        "icon": "$(circle-large-outline)"
      },
      {
        "command": "bunbook.disableSaveOutputs",
        "title": "BunBook: Outputs saved to file (click to disable for cleaner diffs)",
        "shortTitle": "Save Outputs On",
        "icon": "$(pass-filled)"
      }
    ],
    "menus": {
      "notebook/toolbar": [
        {
          "command": "bunbook.restartKernel",
          "group": "navigation/execute@1",
          "when": "(notebookType == 'bunbook' || notebookKernel == 'DavidBuezas.bunbook/bunbook-jupyter-controller') && bunbook.hasWorker"
        },
        {
          "command": "bunbook.enableSaveOutputs",
          "group": "navigation/execute@2",
          "when": "(notebookType == 'bunbook' || notebookKernel == 'DavidBuezas.bunbook/bunbook-jupyter-controller') && !bunbook.persistOutputs"
        },
        {
          "command": "bunbook.disableSaveOutputs",
          "group": "navigation/execute@2",
          "when": "(notebookType == 'bunbook' || notebookKernel == 'DavidBuezas.bunbook/bunbook-jupyter-controller') && bunbook.persistOutputs"
        }
      ],
      "commandPalette": [
        {
          "command": "bunbook.enableSaveOutputs",
          "when": "(notebookType == 'bunbook' || notebookKernel == 'DavidBuezas.bunbook/bunbook-jupyter-controller') && !bunbook.persistOutputs"
        },
        {
          "command": "bunbook.disableSaveOutputs",
          "when": "(notebookType == 'bunbook' || notebookKernel == 'DavidBuezas.bunbook/bunbook-jupyter-controller') && bunbook.persistOutputs"
        }
      ]
    },
    "notebookRenderer": [
      {
        "id": "bunbook-plotly-renderer",
        "displayName": "Plotly Renderer",
        "entrypoint": "./out/renderer/index.js",
        "mimeTypes": [
          "application/vnd.bunbook.plotly"
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "bun build.ts --production",
    "compile": "bun build.ts",
    "start": "rm -f bunbook-*.vsix && vsce package && code --install-extension bunbook-*.vsix",
    "publish": "vsce publish"
  },
  "dependencies": {
    "@types/bun": "^1.3.10",
    "@types/plotly.js": "^3.0.10"
  },
  "packageManager": "bun@1.3.10",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@types/vscode-notebook-renderer": "^1.72.3",
    "@vscode/vsce": "^3.7.1",
    "acorn": "^8.14.0",
    "astring": "^1.9.0",
    "typescript": "^5.3.0"
  }
}

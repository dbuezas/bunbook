{
  "name": "bunbook",
  "displayName": "BunBook",
  "description": "Run TypeScript as a native VS Code notebook with Plotly support",
  "version": "0.0.5",
  "publisher": "DavidBuezas",
  "license": "MIT",
  "repository": "https://github.com/dbuezas/bunbook",
  "keywords": [
    "typescript",
    "notebook",
    "jupyter",
    "bun",
    "plotly",
    "interactive"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Notebooks"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "notebooks": [
      {
        "type": "bunbook",
        "displayName": "TypeScript Notebook",
        "selector": [
          {
            "filenamePattern": "*.bunbook"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "bunbook.newNotebook",
        "title": "Create: New BunBook Notebook",
        "shortTitle": "New BunBook"
      },
      {
        "command": "bunbook.restartKernel",
        "title": "Restart Kernel",
        "shortTitle": "Restart",
        "icon": "$(debug-restart)"
      }
    ],
    "menus": {
      "notebook/toolbar": [
        {
          "command": "bunbook.restartKernel",
          "group": "navigation/execute",
          "when": "notebookType == 'bunbook'"
        }
      ]
    },
    "languages": [
      {
        "id": "bunbook-typescript",
        "aliases": [
          "TypeScript (BunBook)"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "bunbook-typescript",
        "scopeName": "source.ts.bunbook",
        "path": "./syntaxes/bunbook-typescript.tmLanguage.json"
      }
    ],
    "notebookRenderer": [
      {
        "id": "bunbook-plotly-renderer",
        "displayName": "Plotly Renderer",
        "entrypoint": "./out/renderer/index.js",
        "mimeTypes": [
          "application/vnd.plotly+json"
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "node -e \"\" ",
    "compile": "bun build.ts",
    "start": "rm -f bunbook-*.vsix && bun run package && code --install-extension bunbook-*.vsix",
    "package": "bun build.ts --production && rm -rf node_modules && bun install --production && bunx @vscode/vsce package && bun install"
  },
  "dependencies": {
    "@types/bun": "^1.3.10"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@types/vscode-notebook-renderer": "^1.72.3",
    "acorn": "^8.14.0",
    "astring": "^1.9.0",
    "typescript": "^5.3.0"
  }
}
